import { serve } from "https://deno.land/std@0.168.0/http/server.ts";
import { createTransport } from "npm:nodemailer@6.9.7";

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
};

interface EmailRequest {
  to: string;
  subject: string;
  text: string; // Plain text version
  html?: string; // HTML version (optional)
}

const handler = async (req: Request): Promise<Response> => {
  // Handle CORS preflight request
  if (req.method === "OPTIONS") {
    return new Response("ok", { headers: corsHeaders });
  }

  try {
    const { to, subject, text, html } = await req.json() as EmailRequest;

    // Validate inputs
    if (!to || !subject || !text) {
      return new Response(
        JSON.stringify({ error: "Missing required fields: to, subject, text" }),
        { status: 400, headers: { ...corsHeaders, "Content-Type": "application/json" } }
      );
    }

    // Create SMTP transporter
    // Using environment variables for sensitive info
    const transporter = createTransport({
      host: "smtp.qq.com",
      port: 465,
      secure: true, // Use SSL
      auth: {
        user: Deno.env.get("SMTP_USER"), // e.g. 357109648@qq.com
        pass: Deno.env.get("SMTP_PASS"), // The authorization code
      },
    });

    // Send email
    const info = await transporter.sendMail({
      from: `"HHTools" <${Deno.env.get("SMTP_USER")}>`,
      to,
      subject,
      text,
      html: html || text.replace(/\n/g, "<br>"), // Simple fallback if no HTML provided
    });

    console.log("Email sent: %s", info.messageId);

    return new Response(
      JSON.stringify({ message: "Email sent successfully", id: info.messageId }),
      { status: 200, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );

  } catch (error: any) {
    console.error("Error sending email:", error);
    return new Response(
      JSON.stringify({ error: error.message }),
      { status: 500, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );
  }
};

serve(handler);
